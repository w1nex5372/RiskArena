{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RiskArena Character Build v1",
  "type": "object",
  "required": ["schemaVersion", "className", "bodyType", "layers"],
  "properties": {
    "schemaVersion": { "const": "character_build.v1" },
    "className": { "enum": ["warrior", "mage", "rogue"] },
    "bodyType": { "const": "male" },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slot", "asset"],
        "properties": {
          "slot": { "type": "string" },
          "asset": { "type": "string" },
          "variant": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "weapon": {
      "type": "object",
      "properties": {
        "asset": { "type": ["string", "null"] },
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
