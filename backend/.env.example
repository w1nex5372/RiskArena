PG_HOST=localhost
PG_PORT=5432
PG_DB=casino_db
PG_USER=postgres
PG_PASSWORD=postgres
# Render can use DATABASE_URL instead of PG_* values.
DATABASE_URL=
CORS_ORIGINS=http://localhost:3000
ADMIN_KEY=replace-with-a-long-random-admin-key
ALLOW_INSECURE_DEV_AUTH=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_SENSITIVE_MAX=30
RATE_LIMIT_AUTH_MAX=12
RATE_LIMIT_ADMIN_MAX=60
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
SOLANA_RPC_URL=https://api.devnet.solana.com
CASINO_WALLET_PRIVATE_KEY=
CASINO_WALLET_ADDRESS=
