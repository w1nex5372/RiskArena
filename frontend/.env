# Leave backend / gameserver URLs EMPTY so the app uses the current origin and the
# dev-server proxy (src/setupProxy.js: /api, /generated, /colyseus). This makes it work
# BOTH locally (http://localhost:3000) AND through a single tunnel (e.g. Cloudflare
# `cloudflared tunnel --url http://localhost:3000`) for Telegram — where the phone
# cannot reach the dev machine's localhost:8001 / :2567 directly.
# (To force a direct URL for local-only testing, set these to http://localhost:8001 / :2567.)
REACT_APP_BACKEND_URL=
REACT_APP_GAME_SERVER_URL=
WDS_SOCKET_PATH=/riskarena-ws
