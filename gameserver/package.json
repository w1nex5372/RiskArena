{
  "name": "riskarena-gameserver",
  "version": "1.0.0",
  "description": "RiskArena real-time 1v1 arena game server (Colyseus)",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start:built": "node dist/index.js"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.9",
    "axios": "^1.6.8",
    "colyseus": "^0.15.18",
    "express": "^4.18.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.4"
  }
}
